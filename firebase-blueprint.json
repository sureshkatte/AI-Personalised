{
  "entities": {
    "Question": {
      "title": "Question",
      "description": "A quiz question about Ruby language.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The question text." },
        "options": { "type": "array", "items": { "type": "string" }, "description": "Multiple choice options." },
        "correctAnswer": { "type": "integer", "description": "Index of the correct option." },
        "difficulty": { "type": "integer", "description": "Difficulty level from 1 to 5." },
        "topic": { "type": "string", "description": "The specific Ruby topic (e.g., 'Blocks', 'Metaprogramming')." },
        "source": { "type": "string", "enum": ["admin", "ai"], "description": "Whether the question was uploaded by admin or generated by AI." }
      },
      "required": ["text", "options", "correctAnswer", "difficulty", "topic", "source"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User's progress and performance data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "rubyLevel": { "type": "integer", "description": "Current proficiency level (1-5)." },
        "stats": {
          "type": "object",
          "properties": {
            "totalAttempted": { "type": "integer" },
            "totalCorrect": { "type": "integer" }
          }
        },
        "incorrectQuestionIds": { "type": "array", "items": { "type": "string" }, "description": "IDs of questions the user got wrong." }
      },
      "required": ["userId", "email", "rubyLevel"]
    }
  },
  "firestore": {
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Global pool of questions."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User-specific performance data."
    }
  }
}
